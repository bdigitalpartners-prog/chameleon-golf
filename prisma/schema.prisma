enum CircleType {
  FRIENDS
  CLUB
  TRIP
  COMPETITION
  CUSTOM
}

enum CirclePrivacy {
  PUBLIC
  PRIVATE
  SECRET
}

model Circle {
  id                 String          @id @default(cuid())
  name               String          @db.VarChar(255)
  slug               String          @unique @db.VarChar(255)
  description        String?
  type               CircleType      @default(FRIENDS)
  privacy            CirclePrivacy   @default(PRIVATE)
  maxMembers         Int?            @default(50) @map("max_members")
  memberCount        Int             @default(0) @map("member_count")
  verificationMethod String?         @map("verification_method") @db.VarChar(50)
  verificationDomain String?         @map("verification_domain") @db.VarChar(255)
  config             Json?           @default("{}")
  inviteCode         String?         @unique @map("invite_code") @db.VarChar(50)
  imageUrl           String?         @map("image_url") @db.VarChar(500)
  isLeagueEnabled    Boolean         @default(false) @map("is_league_enabled")
  createdById        String          @map("created_by_id")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at")

  createdBy          User            @relation(fields: [createdById], references: [id])
  members            CircleMembership[]
  leagueSeasons      LeagueSeason[]

  @@map("circles")
}

model CircleMembership {
  id              String   @id @default(cuid())
  circleId        String   @map("circle_id")
  userId          String   @map("user_id")
  role            String   @default("MEMBER") @db.VarChar(20)
  membershipTier  String?  @map("membership_tier") @db.VarChar(50)
  joinedAt        DateTime @default(now()) @map("joined_at")

  circle          Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@map("circle_memberships")
}

