// ============================================================================
// EQ TOKEN SYSTEM (needed by existing token code)
// ============================================================================

enum TokenTransactionType {
  EARNED
  SPENT
  EXPIRED
}

enum TokenSource {
  REVIEW
  CHECK_IN
  REFERRAL
  ACHIEVEMENT
  PURCHASE
  ADMIN
  PROFILE
  CHALLENGE
  TRIP
  PREDICTION
}

model EqTokenTransaction {
  id          String               @id @default(cuid())
  userId      String               @map("user_id")
  amount      Int
  type        TokenTransactionType
  source      TokenSource
  description String?              @db.VarChar(500)
  createdAt   DateTime             @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
  @@index([source])
  @@map("eq_token_transactions")
}

model TokenEarningRule {
  id          String      @id @default(cuid())
  source      TokenSource
  action      String      @db.VarChar(100)
  amount      Int
  description String?     @db.VarChar(500)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@unique([source, action])
  @@map("token_earning_rules")
}

model TierConfig {
