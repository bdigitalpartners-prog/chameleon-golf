// ============================================================
// Social Circles — Sprint 1: Social Foundation
// ============================================================

enum ConnectionStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum NotificationLevel {
  ALL
  MENTIONS
  HIGHLIGHTS
  MUTED
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String?  @db.Text
  handicap          Float?
  homeClub          String?
  avatarUrl         String?
  coverUrl          String?
  location          String?
  isAvailableToPlay Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tags              UserTag[]

  @@index([userId])
}

model Connection {
  id          String           @id @default(cuid())
  senderId    String
  sender      User             @relation("ConnectionsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User             @relation("ConnectionsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model Tag {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  category   String?
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())

  users      UserTag[]

  @@index([slug])
  @@index([category])
}

model UserTag {
  id        String      @id @default(cuid())
  userId    String
  profile   UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  tagId     String
  tag       Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, tagId])
  @@index([userId])
  @@index([tagId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?  @db.Text
  actionUrl String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model NotificationPref {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  circleId    String?
  level       NotificationLevel @default(ALL)
  emailDigest Boolean           @default(true)
  pushEnabled Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([userId, circleId])
  @@index([userId])
}

// ============================================================
// Social Circles — Sprint 2: Circle Core
// ============================================================

enum CircleType {
  CREW
  GAME
  NETWORK
  CLUB
  LEAGUE
}

enum CirclePrivacy {
  PUBLIC
  PRIVATE
  SECRET
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  PENDING
  GUEST
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Circle {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  description         String?       @db.Text
  type                CircleType
  privacy             CirclePrivacy @default(PUBLIC)
  avatarUrl           String?
  coverUrl            String?
  memberCount         Int           @default(0)
  maxMembers          Int?
  verificationMethod  String?
  verificationDomain  String?
  config              Json?
  createdById         String
  createdBy           User          @relation(fields: [createdById], references: [id])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  members             CircleMembership[]
  invites             CircleInvite[]

  // Sprint 3
  posts               Post[]
  feedItems           FeedItem[]

  // Sprint 4
  circleCourseRatings    CircleCourseRating[]
  circleCourseAggregates CircleCourseAggregate[]
  circleWishlists        Wishlist[]
  courseCheckIns         CourseCheckIn[]

  // Sprint 5
  clubVerifications   ClubVerification[]
  conditionReports    ConditionReport[]
  circleEvents        CircleEvent[]
  discussionThreads   DiscussionThread[]

  // Sprint 6
  games               Game[]
  headToHeads         HeadToHead[]
  leagueSeasons       LeagueSeason[]

  // Sprint 7
  circleScoreWeights  CircleScoreWeight[]
  circleConsensus     CircleConsensus[]
  tripPlans           TripPlan[]

  // Sprint 8
  courseRecommendations CourseRecommendation[]

  @@index([type])
  @@index([privacy])
  @@index([slug])
  @@index([createdById])
}

model CircleMembership {
  id              String     @id @default(cuid())
  circleId        String
  circle          Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            MemberRole @default(MEMBER)
  joinedAt        DateTime   @default(now())
  verifiedAt      DateTime?
  membershipTier  String?

  @@unique([circleId, userId])
  @@index([circleId])
  @@index([userId])
  @@index([role])
}

model CircleInvite {
  id              String       @id @default(cuid())
  circleId        String
  circle          Circle       @relation(fields: [circleId], references: [id], onDelete: Cascade)
  inviterId       String
  inviter         User         @relation("InvitesSent", fields: [inviterId], references: [id])
  inviteeId       String?
  invitee         User?        @relation("InvitesReceived", fields: [inviteeId], references: [id])
  inviteeEmail    String?
  inviteCode      String?      @unique
  status          InviteStatus @default(PENDING)
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())

  @@index([circleId])
  @@index([inviteeId])
  @@index([inviteCode])
  @@index([inviteeEmail])
}

// ============================================================
// Feed & Engagement — Sprint 3
// ============================================================

enum PostType {
  TEXT
  PHOTO
  ROUND_RECAP
  REVIEW
}

model Post {
  id            String     @id @default(cuid())
  authorId      String
  author        User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  circleId      String
  circle        Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  content       String?    @db.Text
  type          PostType   @default(TEXT)
  mediaUrls     String[]
  courseId       Int?
  course        Course?    @relation(fields: [courseId], references: [courseId])
  isPinned      Boolean    @default(false)
  fistBumpCount Int        @default(0)
  commentCount  Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  fistBumps     FistBump[]
  comments      Comment[]
  mentions      Mention[]
  feedItems     FeedItem[]

  @@index([circleId, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([courseId])
}

model FistBump {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId        String
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model Comment {
  id            String    @id @default(cuid())
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId        String
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  content       String    @db.Text
  parentId      String?
  parent        Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies       Comment[] @relation("CommentReplies")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  mentions      Mention[]

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
}

model FeedItem {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  actorId       String
  actor         User     @relation("FeedActor", fields: [actorId], references: [id])
  circleId      String?
  circle        Circle?  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  postId        String?
  post          Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  courseId       Int?
  course        Course?  @relation(fields: [courseId], references: [courseId])
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, circleId, createdAt(sort: Desc)])
  @@index([actorId])
}

model Mention {
  id               String   @id @default(cuid())
  mentionedUserId  String
  mentionedUser    User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)
  postId           String?
  post             Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId        String?
  comment          Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([mentionedUserId])
  @@index([postId])
  @@index([commentId])
}

// ============================================================
// Course Integration — Sprint 4
// ============================================================

model CircleCourseRating {
  id            String   @id @default(cuid())
  circleId      String
  circle        Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId       Int
  course        Course   @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  overallScore  Float
  dimensions    Json?
  reviewText    String?  @db.Text
  playDate      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([circleId, userId, courseId])
  @@index([circleId, courseId])
  @@index([userId])
  @@index([courseId])
}

model CircleCourseAggregate {
  id              String   @id @default(cuid())
  circleId        String
  circle          Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  courseId         Int
  course          Course   @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  avgScore        Float
  ratingCount     Int      @default(0)
  dimensionAvgs   Json?
  rank            Int?
  lastUpdated     DateTime @default(now())

  @@unique([circleId, courseId])
  @@index([circleId, avgScore(sort: Desc)])
  @@index([courseId])
}

model Wishlist {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     Int
  course      Course   @relation("CircleWishlists", fields: [courseId], references: [courseId], onDelete: Cascade)
  circleId    String?
  circle      Circle?  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  notes       String?  @db.Text
  priority    Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([userId, courseId, circleId])
  @@index([userId])
  @@index([circleId])
  @@index([courseId])
}

model CourseCheckIn {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     Int
  course      Course   @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  circleId    String?
  circle      Circle?  @relation(fields: [circleId], references: [id])
  playDate    DateTime @default(now())
  score       Int?
  photos      String[]
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([courseId])
  @@index([circleId])
}

// ============================================================
// Club Circles & Verification — Sprint 5
// ============================================================

enum VerificationMethod {
  DOCUMENT
  VOUCHING
  DOMAIN
  ADMIN_MANUAL
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model ClubVerification {
  id              String             @id @default(cuid())
  circleId        String
  circle          Circle             @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  method          VerificationMethod
  status          VerificationStatus @default(PENDING)
  evidenceUrl     String?
  vouchedBy       String[]
  domainEmail     String?
  reviewedBy      String?
  reviewNotes     String?
  verifiedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([circleId, userId])
  @@index([circleId, status])
  @@index([userId])
}

model ConditionReport {
  id               String   @id @default(cuid())
  circleId         String
  circle           Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  courseId          Int
  course           Course   @relation(fields: [courseId], references: [courseId])
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  greensSpeed      Int?
  fairwayFirmness  Int?
  roughHeight      Int?
  bunkerCondition  Int?
  overallCondition Int?
  weatherImpact    String?
  notes            String?  @db.Text
  photos           String[]
  reportDate       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([circleId, reportDate(sort: Desc)])
  @@index([courseId])
  @@index([userId])
}

enum EventType {
  TEE_TIME
  TOURNAMENT
  SOCIAL
  MEMBER_GUEST
  COURSE_OUTING
}

model CircleEvent {
  id              String    @id @default(cuid())
  circleId        String
  circle          Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])
  title           String
  description     String?   @db.Text
  courseId         Int?
  course          Course?   @relation(fields: [courseId], references: [courseId])
  eventType       EventType @default(TEE_TIME)
  startDate       DateTime
  endDate         DateTime?
  rsvpDeadline    DateTime?
  maxAttendees    Int?
  location        String?
  coverUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rsvps           EventRSVP[]

  @@index([circleId, startDate])
  @@index([courseId])
}

enum RSVPStatus {
  GOING
  MAYBE
  DECLINED
}

model EventRSVP {
  id          String      @id @default(cuid())
  eventId     String
  event       CircleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      RSVPStatus  @default(GOING)
  guestCount  Int         @default(0)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

enum ThreadCategory {
  CONDITIONS
  EVENTS
  DINING
  PRO_SHOP
  GENERAL
  TIPS
}

model DiscussionThread {
  id          String         @id @default(cuid())
  circleId    String
  circle      Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  authorId    String
  author      User           @relation("ThreadsCreated", fields: [authorId], references: [id])
  title       String
  category    ThreadCategory @default(GENERAL)
  isPinned    Boolean        @default(false)
  isLocked    Boolean        @default(false)
  replyCount  Int            @default(0)
  lastReplyAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  replies     ThreadReply[]

  @@index([circleId, isPinned, lastReplyAt(sort: Desc)])
  @@index([circleId, category])
}

model ThreadReply {
  id          String           @id @default(cuid())
  threadId    String
  thread      DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId    String
  author      User             @relation("ThreadReplies", fields: [authorId], references: [id])
  content     String           @db.Text
  mediaUrls   String[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId])
}

// ============================================================
// Circles Social Messaging
// ============================================================

enum ConversationType {
  DIRECT
  CIRCLE
  COURSE
}

model Conversation {
  id          String           @id @default(cuid())
  type        ConversationType @default(DIRECT)
  title       String?          @db.VarChar(255)
  circleId    String?          @map("circle_id")
  courseId    Int?             @map("course_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@index([circleId])
  @@index([courseId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")
  lastReadAt     DateTime @default(now()) @map("last_read_at")
  muted          Boolean  @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  videoUrl       String?  @map("video_url") @db.VarChar(500)
  videoTitle     String?  @map("video_title") @db.VarChar(255)
  replyToId      String?  @map("reply_to_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]    @relation("MessageReplies")

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ============================================================
// Games & Competitions — Sprint 6
// ============================================================

enum GameFormat {
  SKINS
  NASSAU
  WOLF
  MATCH_PLAY
  BEST_BALL
  SCRAMBLE
  STABLEFORD
  SHAMBLE
  STROKE_PLAY
}

enum GameStatus {
  SETUP
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PlayerStatus {
  CONFIRMED
  TENTATIVE
  WITHDRAWN
}

model Game {
  id            String     @id @default(cuid())
  circleId      String
  circle        Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User       @relation(fields: [createdById], references: [id])
  format        GameFormat
  courseId       Int?
  course        Course?    @relation(fields: [courseId], references: [courseId])
  name          String?
  startDate     DateTime?
  endDate       DateTime?
  status        GameStatus @default(SETUP)
  config        Json?
  holesPlayed   Int        @default(18)
  results       Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  players       GamePlayer[]
  scores        GameScore[]
  sideGames     SideGame[]

  @@index([circleId, status])
  @@index([courseId])
  @@index([createdById])
}

model GamePlayer {
  id            String       @id @default(cuid())
  gameId        String
  game          Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team          String?
  handicap      Float?
  startingHole  Int          @default(1)
  status        PlayerStatus @default(CONFIRMED)
  position      Int?

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

model GameScore {
  id            String   @id @default(cuid())
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holeNumber    Int
  strokes       Int
  putts         Int?
  penalties     Int?
  fairwayHit    Boolean?
  greenInReg    Boolean?
  createdAt     DateTime @default(now())

  @@unique([gameId, userId, holeNumber])
  @@index([gameId, userId])
  @@index([gameId, holeNumber])
}

model SideGame {
  id          String   @id @default(cuid())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name        String
  type        String
  stakes      String?
  holeNumber  Int?
  results     Json?
  createdAt   DateTime @default(now())

  @@index([gameId])
}

model HeadToHead {
  id            String   @id @default(cuid())
  userId1       String
  user1         User     @relation("H2HUser1", fields: [userId1], references: [id], onDelete: Cascade)
  userId2       String
  user2         User     @relation("H2HUser2", fields: [userId2], references: [id], onDelete: Cascade)
  circleId      String
  circle        Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  wins1         Int      @default(0)
  wins2         Int      @default(0)
  ties          Int      @default(0)
  lastPlayed    DateTime?
  courseBreakdown Json?

  @@unique([userId1, userId2, circleId])
  @@index([circleId])
  @@index([userId1])
  @@index([userId2])
}

model LeagueSeason {
  id            String   @id @default(cuid())
  circleId      String
  circle        Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  name          String
  startDate     DateTime
  endDate       DateTime
  status        GameStatus @default(SETUP)
  pointSystem   Json?
  divisions     Json?
  playoffConfig Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  standings     LeagueStanding[]

  @@index([circleId, status])
}

model LeagueStanding {
  id          String       @id @default(cuid())
  seasonId    String
  season      LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  division    String?
  points      Float        @default(0)
  wins        Int          @default(0)
  losses      Int          @default(0)
  ties        Int          @default(0)
  gamesPlayed Int          @default(0)
  rank        Int?
  updatedAt   DateTime     @updatedAt

  @@unique([seasonId, userId])
  @@index([seasonId, rank])
  @@index([userId])
}

// ============================================================
// Chameleon Score Integration — Sprint 7
// ============================================================

model CircleScoreWeight {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  circleId    String
  circle      Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  weight      Float   @default(0.5)
  enabled     Boolean @default(true)
  updatedAt   DateTime @updatedAt

  @@unique([userId, circleId])
  @@index([userId])
}

model CircleConsensus {
  id              String   @id @default(cuid())
  circleId        String
  circle          Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  courseId         Int
  course          Course   @relation(fields: [courseId], references: [courseId])
  consensusScore  Float
  agreementLevel  Float
  comparedToNational Float?
  outlierUserIds  String[]
  lastUpdated     DateTime @default(now())

  @@unique([circleId, courseId])
  @@index([circleId])
  @@index([courseId])
}

model TripPlan {
  id          String   @id @default(cuid())
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  circleId    String
  circle      Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  title       String
  destination String?
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("PLANNING")
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     TripCourse[]
  votes       TripVote[]

  @@index([circleId])
  @@index([creatorId])
}

model TripCourse {
  id          String   @id @default(cuid())
  tripId      String
  trip        TripPlan @relation(fields: [tripId], references: [id], onDelete: Cascade)
  courseId     Int
  course      Course   @relation(fields: [courseId], references: [courseId])
  playDate    DateTime?
  teeTime     String?
  playOrder   Int      @default(0)
  confirmed   Boolean  @default(false)
  notes       String?

  @@unique([tripId, courseId])
  @@index([tripId])
}

model TripVote {
  id          String   @id @default(cuid())
  tripId      String
  trip        TripPlan @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     Int
  course      Course   @relation(fields: [courseId], references: [courseId])
  vote        Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([tripId, userId, courseId])
  @@index([tripId])
  @@index([userId])
}

// ============================================================
// Discovery & Launch — Sprint 8
// ============================================================

model CourseRecommendation {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId       Int
  course        Course   @relation(fields: [courseId], references: [courseId])
  score         Float
  reason        String
  sourceCircleId String?
  sourceCircle  Circle?  @relation(fields: [sourceCircleId], references: [id])
  dismissed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId, dismissed, score(sort: Desc)])
}

model OnboardingProgress {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileComplete Boolean  @default(false)
  tagsSelected    Boolean  @default(false)
  friendsAdded    Boolean  @default(false)
  circleJoined    Boolean  @default(false)
  coursesRated    Boolean  @default(false)
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContentReport {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  contentType String
  contentId   String
  reason      String
  details     String?  @db.Text
  status      String   @default("PENDING")
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([contentType, contentId])
  @@index([reporterId])
}
