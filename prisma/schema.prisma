  status          VerificationStatus @default(PENDING)
  evidenceUrl     String?
  vouchedBy       String[]
  domainEmail     String?
  reviewedBy      String?
  reviewNotes     String?
  verifiedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([circleId, userId])
  @@index([circleId, status])
  @@index([userId])
}

model ConditionReport {
  id               String   @id @default(cuid())
  circleId         String
  circle           Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  courseId          Int
  course           Course   @relation(fields: [courseId], references: [courseId])
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  greensSpeed      Int?
  fairwayFirmness  Int?
  roughHeight      Int?
  bunkerCondition  Int?
  overallCondition Int?
  weatherImpact    String?
  notes            String?  @db.Text
  photos           String[]
  reportDate       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([circleId, reportDate(sort: Desc)])
  @@index([courseId])
  @@index([userId])
}

enum EventType {
  TEE_TIME
  TOURNAMENT
  SOCIAL
  MEMBER_GUEST
  COURSE_OUTING
}

model CircleEvent {
  id              String    @id @default(cuid())
  circleId        String
  circle          Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])
  title           String
  description     String?   @db.Text
  courseId         Int?
  course          Course?   @relation(fields: [courseId], references: [courseId])
  eventType       EventType @default(TEE_TIME)
  startDate       DateTime
  endDate         DateTime?
  rsvpDeadline    DateTime?
  maxAttendees    Int?
  location        String?
  coverUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rsvps           EventRSVP[]

  @@index([circleId, startDate])
  @@index([courseId])
}

enum RSVPStatus {
  GOING
  MAYBE
  DECLINED
}

model EventRSVP {
  id          String      @id @default(cuid())
  eventId     String
  event       CircleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      RSVPStatus  @default(GOING)
  guestCount  Int         @default(0)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

enum ThreadCategory {
  CONDITIONS
  EVENTS
  DINING
  PRO_SHOP
  GENERAL
  TIPS
}

model DiscussionThread {
  id          String         @id @default(cuid())
  circleId    String
  circle      Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  authorId    String
  author      User           @relation("ThreadsCreated", fields: [authorId], references: [id])
  title       String
  category    ThreadCategory @default(GENERAL)
  isPinned    Boolean        @default(false)
  isLocked    Boolean        @default(false)
  replyCount  Int            @default(0)
  lastReplyAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  replies     ThreadReply[]

  @@index([circleId, isPinned, lastReplyAt(sort: Desc)])
  @@index([circleId, category])
}

model ThreadReply {
  id          String           @id @default(cuid())
  threadId    String
  thread      DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId    String
  author      User             @relation("ThreadReplies", fields: [authorId], references: [id])
  content     String           @db.Text
  mediaUrls   String[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId])
}

// ─── Sprint 6: Games & Competitions ────────────────────────────────

enum GameFormat {
  SKINS
  NASSAU
  WOLF
  MATCH_PLAY
  BEST_BALL
  SCRAMBLE
  STABLEFORD
  SHAMBLE
  STROKE_PLAY
}

enum GameStatus {
  SETUP
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PlayerStatus {
  CONFIRMED
  TENTATIVE
  WITHDRAWN
}

model Game {
  id            String     @id @default(cuid())
  circleId      String
  circle        Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User       @relation(fields: [createdById], references: [id])
  format        GameFormat
  courseId       Int?
  course        Course?    @relation(fields: [courseId], references: [courseId])
  name          String?
  startDate     DateTime?
  endDate       DateTime?
  status        GameStatus @default(SETUP)
  config        Json?
  holesPlayed   Int        @default(18)
  results       Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  players       GamePlayer[]
  scores        GameScore[]
  sideGames     SideGame[]

  @@index([circleId, status])
  @@index([courseId])
  @@index([createdById])
}

model GamePlayer {
  id            String       @id @default(cuid())
  gameId        String
  game          Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team          String?
  handicap      Float?
  startingHole  Int          @default(1)
  status        PlayerStatus @default(CONFIRMED)
  position      Int?

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

model GameScore {
  id            String   @id @default(cuid())
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holeNumber    Int
  strokes       Int
  putts         Int?
  penalties     Int?
  fairwayHit    Boolean?
  greenInReg    Boolean?
  createdAt     DateTime @default(now())

  @@unique([gameId, userId, holeNumber])
  @@index([gameId, userId])
  @@index([gameId, holeNumber])
}

model SideGame {
  id          String   @id @default(cuid())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name        String
  type        String
  stakes      String?
  holeNumber  Int?
  results     Json?
  createdAt   DateTime @default(now())

  @@index([gameId])
}

model HeadToHead {
  id            String   @id @default(cuid())
  userId1       String
  user1         User     @relation("H2HUser1", fields: [userId1], references: [id], onDelete: Cascade)
  userId2       String
  user2         User     @relation("H2HUser2", fields: [userId2], references: [id], onDelete: Cascade)
  circleId      String
  circle        Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  wins1         Int      @default(0)
  wins2         Int      @default(0)
  ties          Int      @default(0)
  lastPlayed    DateTime?
  courseBreakdown Json?

  @@unique([userId1, userId2, circleId])
  @@index([circleId])
  @@index([userId1])
  @@index([userId2])
}

model LeagueSeason {
  id            String   @id @default(cuid())
  circleId      String
  circle        Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  name          String
  startDate     DateTime
  endDate       DateTime
  status        GameStatus @default(SETUP)
  pointSystem   Json?
  divisions     Json?
  playoffConfig Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  standings     LeagueStanding[]

  @@index([circleId, status])
}

model LeagueStanding {
  id          String       @id @default(cuid())
  seasonId    String
  season      LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  division    String?
  points      Float        @default(0)
  wins        Int          @default(0)
  losses      Int          @default(0)
  ties        Int          @default(0)
  gamesPlayed Int          @default(0)
  rank        Int?
  updatedAt   DateTime     @updatedAt

  @@unique([seasonId, userId])
  @@index([seasonId, rank])
  @@index([userId])
}
