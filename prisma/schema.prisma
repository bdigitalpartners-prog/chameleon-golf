generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  courseId            Int      @id @default(autoincrement()) @map("course_id")
  courseName          String   @map("course_name") @db.VarChar(255)
  facilityName        String?  @map("facility_name") @db.VarChar(255)
  streetAddress       String?  @map("street_address") @db.VarChar(255)
  city                String?  @db.VarChar(100)
  state               String?  @db.VarChar(100)
  zipCode             String?  @map("zip_code") @db.VarChar(20)
  country             String   @default("United States") @db.VarChar(100)
  latitude            Decimal? @db.Decimal(10, 7)
  longitude           Decimal? @db.Decimal(10, 7)
  courseType           String?  @map("course_type") @db.VarChar(50)
  accessType           String?  @map("access_type") @db.VarChar(50)
  numHoles             Int?     @default(18) @map("num_holes")
  par                  Int?
  yearOpened           Int?     @map("year_opened")
  courseStyle           String?  @map("course_style") @db.VarChar(50)
  originalArchitect    String?  @map("original_architect") @db.VarChar(255)
  renovationArchitect  String?  @map("renovation_architect") @db.VarChar(255)
  renovationYear       Int?     @map("renovation_year")
  renovationNotes      String?  @map("renovation_notes")
  websiteUrl           String?  @map("website_url") @db.VarChar(500)
  phone                String?  @db.VarChar(50)
  greenFeeLow          Decimal? @map("green_fee_low") @db.Decimal(12, 2)
  greenFeeHigh         Decimal? @map("green_fee_high") @db.Decimal(12, 2)
  greenFeeCurrency     String?  @default("USD") @map("green_fee_currency") @db.VarChar(3)
  walkingPolicy        String?  @map("walking_policy") @db.VarChar(50)
  numListsAppeared     Int?     @default(0) @map("num_lists_appeared")
  dataSources          String?  @map("data_sources")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @map("updated_at")
  isVerified           Boolean  @default(false) @map("is_verified")
  isEnriched           Boolean  @default(false) @map("is_enriched")
  description          String?

  // Access & Policies
  email               String?
  tagline             String?
  priceTier           String?   @map("price_tier")
  dressCode           String?   @map("dress_code")
  caddieAvailability  String?   @map("caddie_availability")
  caddieFee           String?   @map("caddie_fee")
  cartPolicy          String?   @map("cart_policy")
  cartFee             String?   @map("cart_fee")
  cellPhonePolicy     String?   @map("cell_phone_policy")
  practiceFacilities  Json?     @map("practice_facilities")
  clubRentalAvailable Boolean?  @map("club_rental_available")
  bookingUrl          String?   @map("booking_url") @db.VarChar(500)
  howToGetOn          String?   @map("how_to_get_on")
  resortAffiliateAccess String? @map("resort_affiliate_access")
  guestPolicy         String?   @map("guest_policy")

  // Course Character & Insider Tips
  signatureHoleNumber  Int?      @map("signature_hole_number")
  signatureHoleDescription String? @map("signature_hole_description")
  bestPar3            Json?     @map("best_par3")
  bestPar4            Json?     @map("best_par4")
  bestPar5            Json?     @map("best_par5")
  insiderTips         Json?     @map("insider_tips")
  courseStrategy       String?   @map("course_strategy")
  whatToExpect         String?   @map("what_to_expect")
  bestTimeToPlay      String?   @map("best_time_to_play")
  paceOfPlayNotes     String?   @map("pace_of_play_notes")

  // Conditions
  fairwayGrass        String?   @map("fairway_grass")
  greenGrass          String?   @map("green_grass")
  greenSpeed          String?   @map("green_speed")
  aerationSchedule    String?   @map("aeration_schedule")
  bestConditionMonths String?   @map("best_condition_months")
  golfSeason          String?   @map("golf_season")

  // Championship & History
  championshipHistory Json?     @map("championship_history")
  famousMoments       Json?     @map("famous_moments")
  upcomingEvents      Json?     @map("upcoming_events")

  // Weather
  weatherData         Json?     @map("weather_data")
  bestMonths          Json?     @map("best_months")
  worstMonths         Json?     @map("worst_months")

  // Architecture
  architectBio        String?   @map("architect_bio")
  designPhilosophy    String?   @map("design_philosophy")
  templateHoles       Json?     @map("template_holes")
  renovationHistory   Json?     @map("renovation_history")

  // Lodging
  onSiteLodging       Boolean?  @map("on_site_lodging")
  resortNameField     String?   @map("resort_name") @db.VarChar(255)
  resortBookingUrl    String?   @map("resort_booking_url") @db.VarChar(500)
  stayAndPlayPackages Json?     @map("stay_and_play_packages")

  // Pace of Play
  averageRoundTime    String?   @map("average_round_time")

  // Pricing Details
  greenFeePeak        Decimal?  @map("green_fee_peak") @db.Decimal(12, 2)
  greenFeeOffPeak     Decimal?  @map("green_fee_off_peak") @db.Decimal(12, 2)
  greenFeeTwilight    Decimal?  @map("green_fee_twilight") @db.Decimal(12, 2)
  includesCart        Boolean?  @map("includes_cart")

  rankings         RankingEntry[]
  media            CourseMedia[]
  airports         CourseAirportProximity[]
  ratings          UserCourseRating[]
  scores           PostedScore[]
  chameleonScores  ChameleonScore?
  holes            Hole[]
  teeBoxes         TeeBox[]

  // New relations
  nearbyDining      CourseNearbyDining[]
  nearbyLodging     CourseNearbyLodging[]
  nearbyAttractions CourseNearbyAttractions[]
  wishlists         CourseWishlist[]
  nearbyCourses     CourseNearbyCourses[] @relation("SourceCourse")
  nearbyFrom        CourseNearbyCourses[] @relation("NearbyCourse")
  nearbyRvParks     CourseNearbyRvParks[]
  intelligenceNotes CourseIntelligenceNotes[]
  weatherMonths     CourseWeather[]

  // Social Links
  instagramUrl      String?   @map("instagram_url") @db.VarChar(500)
  twitterUrl        String?   @map("twitter_url") @db.VarChar(500)
  facebookUrl       String?   @map("facebook_url") @db.VarChar(500)
  tiktokUrl         String?   @map("tiktok_url") @db.VarChar(500)

  // Architect enrichment
  architectId       Int?      @map("architect_id")
  architect         Architect? @relation(fields: [architectId], references: [id])
  courseArchitects   CourseArchitect[]
  externalContent   ContentCourseLink[]
  books             BookCourseLink[]

  // Sprint 3 — Feed & Engagement
  coursePosts            Post[]
  courseFeedItems        FeedItem[]

  // Sprint 4 — Course Integration
  circleCourseRatings    CircleCourseRating[]
  circleCourseAggregates CircleCourseAggregate[]
  circleWishlistEntries  Wishlist[]             @relation("CircleWishlists")
  courseCheckIns         CourseCheckIn[]

  // Sprint 5 — Club Circles
  conditionReports       ConditionReport[]
  circleEvents           CircleEvent[]

  // Sprint 6 — Games
  games                  Game[]

  // Sprint 7 — Chameleon Score Integration
  circleConsensus        CircleConsensus[]
  tripCourses            TripCourse[]
  courseTripVotes        TripVote[]

  // Sprint 8 — Discovery
  courseRecommendations  CourseRecommendation[]

  @@map("courses")
}

model RankingSource {
  sourceId          Int     @id @default(autoincrement()) @map("source_id")
  sourceName        String  @unique @map("source_name") @db.VarChar(100)
  sourceUrl         String? @map("source_url") @db.VarChar(500)
  methodologyNotes  String? @map("methodology_notes")
  authorityWeight   Decimal @default(1.0) @map("authority_weight") @db.Decimal(3, 2)

  lists             RankingList[]

  @@map("ranking_sources")
}

model RankingList {
  listId           Int      @id @default(autoincrement()) @map("list_id")
  sourceId         Int      @map("source_id")
  listName         String   @map("list_name") @db.VarChar(200)
  listType         String?  @map("list_type") @db.VarChar(50)
  region           String?  @db.VarChar(100)
  yearPublished    Int      @map("year_published")
  cycleLabel       String?  @map("cycle_label") @db.VarChar(50)
  accessFilter     String?  @map("access_filter") @db.VarChar(50)
  url              String?  @db.VarChar(500)
  prestigeTier     String   @default("regional") @map("prestige_tier") @db.VarChar(20)
  listWeight       Decimal  @default(0.4) @map("list_weight") @db.Decimal(3, 2)

  source           RankingSource @relation(fields: [sourceId], references: [sourceId])
  entries          RankingEntry[]

  @@unique([sourceId, listName, cycleLabel])
  @@map("ranking_lists")
}

model RankingEntry {
  entryId          Int      @id @default(autoincrement()) @map("entry_id")
  listId           Int      @map("list_id")
  courseId          Int      @map("course_id")
  rankPosition     Int?     @map("rank_position")
  rankTied         Boolean  @default(false) @map("rank_tied")
  score            Decimal? @db.Decimal(5, 2)
  previousRank     Int?     @map("previous_rank")
  rankChange       Int?     @map("rank_change")
  notes            String?

  list             RankingList @relation(fields: [listId], references: [listId], onDelete: Cascade)
  course           Course      @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  @@unique([listId, courseId])
  @@map("ranking_entries")
}

model Airport {
  airportId           Int      @id @default(autoincrement()) @map("airport_id")
  iataCode            String?  @map("iata_code") @db.VarChar(10)
  icaoCode            String?  @map("icao_code") @db.VarChar(10)
  airportName         String   @map("airport_name") @db.VarChar(255)
  airportType         String   @map("airport_type") @db.VarChar(50)
  city                String?  @db.VarChar(100)
  stateProvince       String?  @map("state_province") @db.VarChar(100)
  country             String?  @db.VarChar(100)
  latitude            Decimal? @db.Decimal(10, 7)
  longitude           Decimal? @db.Decimal(10, 7)
  hasScheduledService Boolean  @default(false) @map("has_scheduled_service")
  hasCharterService   Boolean  @default(false) @map("has_charter_service")
  hasFbo              Boolean  @default(false) @map("has_fbo")
  fboNames            String?  @map("fbo_names")
  longestRunwayFt     Int?     @map("longest_runway_ft")

  proximity           CourseAirportProximity[]

  @@map("airports")
}

model CourseAirportProximity {
  id               Int     @id @default(autoincrement())
  courseId          Int     @map("course_id")
  airportId        Int     @map("airport_id")
  distanceMiles    Decimal @map("distance_miles") @db.Decimal(6, 1)
  driveTimeMinutes Int?    @map("drive_time_minutes")

  course           Course  @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  airport          Airport @relation(fields: [airportId], references: [airportId])

  @@unique([courseId, airportId])
  @@map("course_airport_proximity")
}

model CourseMedia {
  mediaId          Int      @id @default(autoincrement()) @map("media_id")
  courseId          Int      @map("course_id")
  mediaType        String?  @map("media_type") @db.VarChar(20)
  imageType        String?  @map("image_type") @db.VarChar(30)
  url              String   @db.VarChar(500)
  localPath        String?  @map("local_path") @db.VarChar(500)
  caption          String?  @db.VarChar(500)
  credit           String?  @db.VarChar(200)
  sourceName       String?  @map("source_name") @db.VarChar(200)
  isPrimary        Boolean  @default(false) @map("is_primary")
  isActive         Boolean  @default(true) @map("is_active")
  sourceUrl        String?  @map("source_url") @db.VarChar(500)
  sortOrder        Int      @default(0) @map("sort_order")
  uploadedBy       String?  @map("uploaded_by")
  createdAt        DateTime @default(now()) @map("created_at")

  course           Course   @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  @@map("course_media")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime? @map("email_verified")
  image           String?
  ghinNumber      String?   @map("ghin_number") @db.VarChar(20)
  handicapIndex   Decimal?  @map("handicap_index") @db.Decimal(4, 1)
  homeCourseId    Int?      @map("home_course_id")
  homeState       String?   @map("home_state") @db.VarChar(100)
  ghinVerified    Boolean   @default(false) @map("ghin_verified")
  ghinVerifiedAt  DateTime? @map("ghin_verified_at")
  ghinLastSynced  DateTime? @map("ghin_last_synced")
  role            String    @default("user") @db.VarChar(20)
  isActive        Boolean   @default(true) @map("is_active")
  instagramUrl    String?   @map("instagram_url") @db.VarChar(500)
  twitterUrl      String?   @map("twitter_url") @db.VarChar(500)
  facebookUrl     String?   @map("facebook_url") @db.VarChar(500)
  tiktokUrl       String?   @map("tiktok_url") @db.VarChar(500)
  websiteUrl      String?   @map("website_url") @db.VarChar(500)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  ratings         UserCourseRating[]
  scores          PostedScore[]
  weightProfiles  UserWeightProfile[]
  wishlists       CourseWishlist[]

  // Sprint 1 — Social Foundation
  profile              UserProfile?
  connectionsSent      Connection[]           @relation("ConnectionsSent")
  connectionsReceived  Connection[]           @relation("ConnectionsReceived")
  notifications        Notification[]
  notificationPrefs    NotificationPref[]

  // Sprint 2 — Circles Core
  circles              Circle[]
  memberships          CircleMembership[]
  invitesSent          CircleInvite[]         @relation("InvitesSent")
  invitesReceived      CircleInvite[]         @relation("InvitesReceived")

  // Sprint 3 — Feed & Engagement
  posts                Post[]
  fistBumps            FistBump[]
  comments             Comment[]
  feedItems            FeedItem[]
  feedActions          FeedItem[]             @relation("FeedActor")
  mentionedIn          Mention[]

  // Sprint 4 — Course Integration
  circleCourseRatings  CircleCourseRating[]
  courseCheckIns       CourseCheckIn[]
  circleWishlists      Wishlist[]

  // Sprint 5 — Club Circles & Verification
  clubVerifications    ClubVerification[]
  conditionReports     ConditionReport[]
  circleEventsCreated  CircleEvent[]
  eventRSVPs           EventRSVP[]
  threadsCreated       DiscussionThread[]     @relation("ThreadsCreated")
  threadReplies        ThreadReply[]          @relation("ThreadReplies")

  // Social Widget — Messaging
  conversationParticipants ConversationParticipant[]
  messages             Message[]

  // Sprint 6 — Games & Competitions
  gamesCreated         Game[]
  gamePlayers          GamePlayer[]
  gameScores           GameScore[]
  h2hAsUser1           HeadToHead[]           @relation("H2HUser1")
  h2hAsUser2           HeadToHead[]           @relation("H2HUser2")
  leagueStandings      LeagueStanding[]

  // Sprint 7 — Chameleon Score Integration
  circleScoreWeights   CircleScoreWeight[]
  tripsCreated         TripPlan[]
  tripVotes            TripVote[]

  // Sprint 8 — Discovery & Launch
  courseRecommendations CourseRecommendation[]
  onboardingProgress   OnboardingProgress?
  contentReports       ContentReport[]

  @@map("users")
}

model Hole {
  holeId    Int @id @default(autoincrement()) @map("hole_id")
  courseId  Int @map("course_id")
  holeNumber Int @map("hole_number")
  par       Int

  course    Course @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  teeYardages HoleTeeYardage[]

  @@unique([courseId, holeNumber])
  @@map("holes")
}

model TeeBox {
  teeId     Int     @id @default(autoincrement()) @map("tee_id")
  courseId   Int     @map("course_id")
  teeName   String  @map("tee_name") @db.VarChar(50)
  color     String? @db.VarChar(30)
  gender    String? @db.VarChar(10)
  courseRating Decimal? @map("course_rating") @db.Decimal(4, 1)
  slopeRating  Int?     @map("slope_rating")
  totalYardage Int?     @map("total_yardage")

  course    Course @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  yardages  HoleTeeYardage[]

  @@unique([courseId, teeName])
  @@map("tee_boxes")
}

model HoleTeeYardage {
  id      Int @id @default(autoincrement())
  holeId  Int @map("hole_id")
  teeId   Int @map("tee_id")
  yardage Int

  hole    Hole   @relation(fields: [holeId], references: [holeId], onDelete: Cascade)
  tee     TeeBox @relation(fields: [teeId], references: [teeId], onDelete: Cascade)

  @@unique([holeId, teeId])
  @@map("hole_tee_yardages")
}

model PostedScore {
  scoreId             Int       @id @default(autoincrement()) @map("score_id")
  userId              String    @map("user_id")
  courseId             Int       @map("course_id")
  teeId               Int?      @map("tee_id")
  datePlayed          DateTime  @map("date_played") @db.Date
  totalScore          Int       @map("total_score")
  frontNineScore      Int?      @map("front_nine_score")
  backNineScore       Int?      @map("back_nine_score")
  numHolesPlayed      Int       @default(18) @map("num_holes_played")
  holeScores          Json?     @map("hole_scores") @db.JsonB
  adjustedScore       Int?      @map("adjusted_score")
  differential        Decimal?  @db.Decimal(5, 1)
  verificationMethod  String?   @map("verification_method") @db.VarChar(50)
  verificationStatus  String    @default("unverified") @map("verification_status") @db.VarChar(20)
  verifiedAt          DateTime? @map("verified_at")
  verifiedBy          String?   @map("verified_by")
  screenshotUrl       String?   @map("screenshot_url") @db.VarChar(500)
  screenshotUploadAt  DateTime? @map("screenshot_upload_at")
  ghinScoreId         String?   @map("ghin_score_id") @db.VarChar(50)
  ghinPostedAt        DateTime? @map("ghin_posted_at")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")

  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course              Course  @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  @@map("posted_scores")
}

model UserCourseRating {
  ratingId          Int       @id @default(autoincrement()) @map("rating_id")
  userId            String    @map("user_id")
  courseId           Int       @map("course_id")
  scoreId           Int?      @map("score_id")
  overallRating     Decimal   @map("overall_rating") @db.Decimal(3, 1)
  conditioning      Decimal?  @db.Decimal(3, 1)
  layoutDesign      Decimal?  @map("layout_design") @db.Decimal(3, 1)
  paceOfPlay        Decimal?  @map("pace_of_play") @db.Decimal(3, 1)
  aesthetics        Decimal?  @db.Decimal(3, 1)
  challenge         Decimal?  @db.Decimal(3, 1)
  value             Decimal?  @db.Decimal(3, 1)
  amenities         Decimal?  @db.Decimal(3, 1)
  walkability       Decimal?  @db.Decimal(3, 1)
  service           Decimal?  @db.Decimal(3, 1)
  handicapAtRating  Decimal?  @map("handicap_at_rating") @db.Decimal(4, 1)
  reviewTitle       String?   @map("review_title") @db.VarChar(200)
  reviewText        String?   @map("review_text")
  datePlayed        DateTime? @map("date_played") @db.Date
  timesRated        Int       @default(1) @map("times_rated")
  previousRatingId  Int?      @map("previous_rating_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @map("updated_at")
  isPublished       Boolean   @default(true) @map("is_published")
  isSeed            Boolean   @default(false) @map("is_seed")
  seedSource        String?   @map("seed_source") @db.VarChar(200)
  seedReviewerName  String?   @map("seed_reviewer_name") @db.VarChar(200)

  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  @@map("user_course_ratings")
}

model ChameleonScore {
  id                    Int      @id @default(autoincrement())
  courseId              Int      @unique @map("course_id")
  avgOverall           Decimal? @map("avg_overall") @db.Decimal(4, 2)
  avgConditioning      Decimal? @map("avg_conditioning") @db.Decimal(4, 2)
  avgLayoutDesign      Decimal? @map("avg_layout_design") @db.Decimal(4, 2)
  avgPace              Decimal? @map("avg_pace") @db.Decimal(4, 2)
  avgAesthetics        Decimal? @map("avg_aesthetics") @db.Decimal(4, 2)
  avgChallenge         Decimal? @map("avg_challenge") @db.Decimal(4, 2)
  avgValue             Decimal? @map("avg_value") @db.Decimal(4, 2)
  avgAmenities         Decimal? @map("avg_amenities") @db.Decimal(4, 2)
  avgWalkability       Decimal? @map("avg_walkability") @db.Decimal(4, 2)
  avgService           Decimal? @map("avg_service") @db.Decimal(4, 2)
  totalRatings         Int      @default(0) @map("total_ratings")
  prestigeScore        Decimal? @map("prestige_score") @db.Decimal(8, 4)
  numListsAppeared     Int      @default(0) @map("num_lists_appeared")
  bestRankGolfDigest   Int?     @map("best_rank_golf_digest")
  bestRankGolfweek     Int?     @map("best_rank_golfweek")
  bestRankGolfMag      Int?     @map("best_rank_golf_mag")
  bestRankTop100gc     Int?     @map("best_rank_top100gc")
  chameleonScore       Decimal  @map("chameleon_score") @db.Decimal(8, 4)
  computedAt           DateTime @default(now()) @map("computed_at")

  course               Course @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  @@map("chameleon_scores")
}

model RatingHistory {
  historyId         Int       @id @default(autoincrement()) @map("history_id")
  ratingId          Int       @map("rating_id")
  userId            String    @map("user_id")
  courseId           Int       @map("course_id")
  overallRating     Decimal   @map("overall_rating") @db.Decimal(3, 1)
  conditioning      Decimal?  @db.Decimal(3, 1)
  layoutDesign      Decimal?  @map("layout_design") @db.Decimal(3, 1)
  paceOfPlay        Decimal?  @map("pace_of_play") @db.Decimal(3, 1)
  aesthetics        Decimal?  @db.Decimal(3, 1)
  challenge         Decimal?  @db.Decimal(3, 1)
  value             Decimal?  @db.Decimal(3, 1)
  amenities         Decimal?  @db.Decimal(3, 1)
  walkability       Decimal?  @db.Decimal(3, 1)
  service           Decimal?  @db.Decimal(3, 1)
  reviewText        String?   @map("review_text")
  handicapAtRating  Decimal?  @map("handicap_at_rating") @db.Decimal(4, 1)
  datePlayed        DateTime? @map("date_played") @db.Date
  archivedAt        DateTime  @default(now()) @map("archived_at")

  @@map("rating_history")
}

model UserWeightProfile {
  profileId           Int      @id @default(autoincrement()) @map("profile_id")
  userId              String?  @map("user_id")
  profileName         String   @map("profile_name") @db.VarChar(100)
  isActive            Boolean  @default(true) @map("is_active")
  weightConditioning  Decimal  @default(0.10) @map("weight_conditioning") @db.Decimal(4, 3)
