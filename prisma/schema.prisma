model UserChallenge {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  challengeId   String    @map("challenge_id")
  progress      Json?
  progressPct   Decimal   @default(0) @map("progress_pct") @db.Decimal(5, 2)
  status        String    @default("active") @db.VarChar(20)
  completedAt   DateTime? @map("completed_at")
  tokensEarned  Int       @default(0) @map("tokens_earned")
  joinedAt      DateTime  @default(now()) @map("joined_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("user_challenges")
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  description String?
  icon        String?  @db.VarChar(100)
  category    String?  @db.VarChar(50)
  tier        String   @default("bronze") @db.VarChar(20)
  criteria    Json?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  challenges  Challenge[]
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  earnedAt  DateTime @default(now()) @map("earned_at")
  metadata  Json?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Prediction {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  courseId         Int       @map("course_id")
  predictedScore  Int       @map("predicted_score")
  eqBaseline      Int?      @map("eq_baseline")
  actualScore     Int?      @map("actual_score")
  accuracy        Decimal?  @db.Decimal(5, 2)
  beatAlgorithm   Boolean?  @map("beat_algorithm")
  playDate        DateTime? @map("play_date") @db.Date
  status          String    @default("pending") @db.VarChar(20)
  tokensEarned    Int       @default(0) @map("tokens_earned")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course    @relation(fields: [courseId], references: [courseId])

  @@index([userId, createdAt(sort: Desc)])
  @@map("predictions")
}

// ============================================================================
// ENHANCEMENT 6: EQ LEAGUES
// ============================================================================

model LeagueSeason {
  id            String    @id @default(cuid())
  circleId      String    @map("circle_id")
  name          String    @db.VarChar(255)
  startDate     DateTime  @map("start_date") @db.Date
  endDate       DateTime  @map("end_date") @db.Date
  status        String    @default("active") @db.VarChar(20)
  pointSystem   Json?     @map("point_system")
  divisions     Json?
  playoffConfig Json?     @map("playoff_config")
  createdAt     DateTime  @default(now()) @map("created_at")

  circle        Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  standings     LeagueStanding[]
  rounds        LeagueRound[]

  @@index([circleId])
  @@map("league_seasons")
}

model LeagueStanding {
  id            String   @id @default(cuid())
  seasonId      String   @map("season_id")
  userId        String   @map("user_id")
  totalPoints   Decimal  @default(0) @map("total_points") @db.Decimal(10, 2)
  roundsPlayed  Int      @default(0) @map("rounds_played")
  avgEqPoints   Decimal  @default(0) @map("avg_eq_points") @db.Decimal(8, 2)
  rank          Int?
  wins          Int      @default(0)
  losses        Int      @default(0)
  ties          Int      @default(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  season        LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@map("league_standings")
}

model LeagueRound {
  id            String   @id @default(cuid())
  seasonId      String   @map("season_id")
  userId        String   @map("user_id")
  courseId       Int      @map("course_id")
  score         Int
  eqPoints      Decimal  @map("eq_points") @db.Decimal(8, 2)
  matchScore    Decimal? @map("match_score") @db.Decimal(5, 2)
  difficultyMult Decimal? @map("difficulty_mult") @db.Decimal(4, 2)
  playDate      DateTime @map("play_date") @db.Date
  isVerified    Boolean  @default(false) @map("is_verified")
  createdAt     DateTime @default(now()) @map("created_at")

  season        LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course       @relation(fields: [courseId], references: [courseId])

  @@map("league_rounds")
}

// ============================================================================
// ENHANCEMENT 7: EQ ACADEMY & COURSE PREP PACKS
// ============================================================================

model AcademyContent {
  id               String    @id @default(cuid())
  slug             String    @unique @db.VarChar(255)
  title            String    @db.VarChar(255)
  subtitle         String?   @db.VarChar(500)
  category         String    @db.VarChar(100)
  subcategory      String?   @db.VarChar(100)
  difficulty       String?   @db.VarChar(50)
  estimatedTime    String?   @map("estimated_time") @db.VarChar(50)
  heroImage        String?   @map("hero_image") @db.VarChar(500)
  content          String?
  tags             String[]
  eqDimensions     String[]  @map("eq_dimensions")
  videoUrl         String?   @map("video_url") @db.VarChar(500)
  publishedAt      DateTime? @map("published_at")
  featured         Boolean   @default(false)
  sortOrder        Int       @default(0) @map("sort_order")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("academy_content")
}

model PrepPack {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  courseId         Int      @map("course_id")
  keyHoles        Json?    @map("key_holes")
  strategyTips    Json?    @map("strategy_tips")
  clubSuggestions Json?    @map("club_suggestions")
  expectations    Json?
  weatherForecast Json?    @map("weather_forecast")
  similarCourses  Json?    @map("similar_courses")
  fullContent     String?  @map("full_content")
  generatedAt     DateTime @default(now()) @map("generated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course   @relation(fields: [courseId], references: [courseId])

  @@unique([userId, courseId])
  @@map("prep_packs")
}

model CourseDebrief {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  roundId         Int?     @map("round_id")
  courseId         Int?     @map("course_id")
  greensQuality   Int?     @map("greens_quality")
  fairwayQuality  Int?     @map("fairway_quality")
  paceOfPlay      String?  @map("pace_of_play") @db.VarChar(50)
  difficulty      String?  @db.VarChar(50)
  standoutHoles   Json?    @map("standout_holes")
  recommendations String?
  wouldReturn     Boolean?  @map("would_return")
  handicapAdvice  String?   @map("handicap_advice") @db.VarChar(100)
  aiSummary       String?   @map("ai_summary")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("course_debriefs")
}

// ============================================================================
// ENHANCEMENT 8: LIVE SCORING / GHIN ROUND DATA
// ============================================================================

model RoundHistory {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  courseId           Int       @map("course_id")
  ghinRoundId       String?   @map("ghin_round_id") @db.VarChar(100)
  score             Int
  adjustedScore     Int?      @map("adjusted_score")
  differential      Decimal?  @db.Decimal(5, 1)
  teeBoxName        String?   @map("tee_box_name") @db.VarChar(50)
  courseRating       Decimal?  @map("course_rating") @db.Decimal(4, 1)
  slopeRating       Int?      @map("slope_rating")
  playDate          DateTime  @map("play_date") @db.Date
  numHoles          Int       @default(18) @map("num_holes")
  isVerified        Boolean   @default(false) @map("is_verified")
  source            String    @default("manual") @db.VarChar(50)
  rawData           Json?     @map("raw_data")
  createdAt         DateTime  @default(now()) @map("created_at")

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course    @relation(fields: [courseId], references: [courseId])
  verifiedPlay      VerifiedPlay?

  @@index([userId, playDate(sort: Desc)])
  @@map("round_history")
}

model VerifiedPlay {
  id            String   @id @default(cuid())
  roundId       String   @unique @map("round_id")
  userId        String   @map("user_id")
  badgeType     String   @default("ghin_verified") @map("badge_type") @db.VarChar(50)
  verifiedAt    DateTime @default(now()) @map("verified_at")
  verificationSource String @default("ghin") @map("verification_source") @db.VarChar(50)

  round         RoundHistory @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verified_plays")
}
