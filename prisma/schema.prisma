// ============================================================================
// ENHANCEMENT 3: EQ TRIP PLANNER
// ============================================================================

model Trip {
  id              String    @id @default(cuid())
  name            String    @db.VarChar(255)
  destination     String    @db.VarChar(255)
  description     String?
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime  @map("end_date") @db.Date
  budget          String?   @db.VarChar(50)
  groupSize       Int?      @map("group_size")
  status          String    @default("planning") @db.VarChar(20)
  groupMatchScore Decimal?  @map("group_match_score") @db.Decimal(5, 2)
  shareCode       String?   @unique @map("share_code") @db.VarChar(50)
  coverImageUrl   String?   @map("cover_image_url") @db.VarChar(500)
  aiItinerary     Json?     @map("ai_itinerary")
  createdById     String    @map("created_by_id")
  circleId        String?   @map("circle_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  createdBy       User      @relation(fields: [createdById], references: [id])
  participants    TripParticipant[]
  rounds          TripRound[]
  expenses        TripExpense[]
  itinerary       TripItinerary[]

  @@index([createdById])
  @@map("trips")
}

model TripParticipant {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  userId      String   @map("user_id")
  rsvpStatus  String   @default("pending") @map("rsvp_status") @db.VarChar(20)
  role        String   @default("member") @db.VarChar(20)
  joinedAt    DateTime @default(now()) @map("joined_at")

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@map("trip_participants")
}

model TripRound {
  id          String    @id @default(cuid())
  tripId      String    @map("trip_id")
  courseId    Int       @map("course_id")
  playDate    DateTime? @map("play_date") @db.Date
  teeTime     String?   @map("tee_time") @db.VarChar(10)
  matchScore  Decimal?  @map("match_score") @db.Decimal(5, 2)
  notes       String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")

  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [courseId])

  @@map("trip_rounds")
}

model TripExpense {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  paidById    String   @map("paid_by_id")
  description String   @db.VarChar(255)
  amount      Decimal  @db.Decimal(10, 2)
  category    String?  @db.VarChar(50)
  splitType   String   @default("equal") @map("split_type") @db.VarChar(20)
  splitData   Json?    @map("split_data")
  createdAt   DateTime @default(now()) @map("created_at")

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  paidBy      User     @relation(fields: [paidById], references: [id])

  @@map("trip_expenses")
}

model TripItinerary {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  dayNumber   Int      @map("day_number")
  itemType    String   @map("item_type") @db.VarChar(50)
  title       String   @db.VarChar(255)
  description String?
  location    String?  @db.VarChar(255)
  startTime   String?  @map("start_time") @db.VarChar(10)
  endTime     String?  @map("end_time") @db.VarChar(10)
  metadata    Json?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("trip_itinerary")
}

// ============================================================================
// ENHANCEMENT 4: EQ EVENTS DISCOVERY
// ============================================================================

model Event {
  id                String    @id @default(cuid())
  name              String    @db.VarChar(255)
  description       String?
  courseId           Int?      @map("course_id")
  courseName        String?   @map("course_name") @db.VarChar(255)
  eventDate         DateTime  @map("event_date") @db.Date
  endDate           DateTime? @map("end_date") @db.Date
  format            String?   @db.VarChar(100)
  price             Decimal?  @db.Decimal(10, 2)
  maxHandicap       Decimal?  @map("max_handicap") @db.Decimal(4, 1)
  minHandicap       Decimal?  @map("min_handicap") @db.Decimal(4, 1)
  registrationUrl   String?   @map("registration_url") @db.VarChar(500)
  source            String    @default("manual") @db.VarChar(50)
  sourceEventId     String?   @map("source_event_id") @db.VarChar(100)
  city              String?   @db.VarChar(100)
  state             String?   @db.VarChar(100)
  imageUrl          String?   @map("image_url") @db.VarChar(500)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  course            Course?   @relation(fields: [courseId], references: [courseId])
  matches           EventMatch[]
  registrations     EventRegistration[]

  @@index([eventDate])
  @@index([state])
  @@map("events")
}

model EventMatch {
  id          String   @id @default(cuid())
  eventId     String   @map("event_id")
  courseId     Int      @map("course_id")
  matchScore  Decimal  @map("match_score") @db.Decimal(5, 2)
  computedAt  DateTime @default(now()) @map("computed_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [courseId])

  @@unique([eventId, courseId])
  @@map("event_matches")
}

model EventRegistration {
  id          String   @id @default(cuid())
  eventId     String   @map("event_id")
  userId      String   @map("user_id")
  status      String   @default("interested") @db.VarChar(20)
  registeredAt DateTime @default(now()) @map("registered_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_registrations")
}

