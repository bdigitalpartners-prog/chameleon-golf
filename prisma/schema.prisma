}

model NotificationPref {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  circleId    String?
  level       NotificationLevel @default(ALL)
  emailDigest Boolean           @default(true)
  pushEnabled Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([userId, circleId])
  @@index([userId])

}

model OnboardingProgress {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileComplete Boolean  @default(false)
  tagsSelected    Boolean  @default(false)
  friendsAdded    Boolean  @default(false)
  circleJoined    Boolean  @default(false)
  coursesRated    Boolean  @default(false)
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

}

model Post {
  id            String     @id @default(cuid())
  authorId      String
  author        User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  circleId      String
  circle        Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  content       String?    @db.Text
  type          PostType   @default(TEXT)
  mediaUrls     String[]
  courseId       Int?
  course        Course?    @relation(fields: [courseId], references: [courseId])
  isPinned      Boolean    @default(false)
  fistBumpCount Int        @default(0)
  commentCount  Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  fistBumps     FistBump[]
  comments      Comment[]
  mentions      Mention[]
  feedItems     FeedItem[]

  @@index([circleId, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([courseId])

}

model SideGame {
  id          String   @id @default(cuid())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name        String
  type        String
  stakes      String?
  holeNumber  Int?
  results     Json?
  createdAt   DateTime @default(now())

  @@index([gameId])

}

model Tag {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  category   String?
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())

  users      UserTag[]

  @@index([slug])
  @@index([category])

}

model ThreadReply {
  id          String           @id @default(cuid())
  threadId    String
  thread      DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId    String
  author      User             @relation("ThreadReplies", fields: [authorId], references: [id])
  content     String           @db.Text
  mediaUrls   String[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId])

}

model TripCourse {
  id          String   @id @default(cuid())
  tripId      String
  trip        TripPlan @relation(fields: [tripId], references: [id], onDelete: Cascade)
  courseId     Int
  course      Course   @relation(fields: [courseId], references: [courseId])
  playDate    DateTime?
  teeTime     String?
  playOrder   Int      @default(0)
  confirmed   Boolean  @default(false)
  notes       String?

  @@unique([tripId, courseId])
  @@index([tripId])

}

model TripPlan {
  id          String   @id @default(cuid())
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  circleId    String
  circle      Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  title       String
  destination String?
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("PLANNING")
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     TripCourse[]
  votes       TripVote[]

  @@index([circleId])
  @@index([creatorId])

}

model TripVote {
  id          String   @id @default(cuid())
  tripId      String
  trip        TripPlan @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     Int
  course      Course   @relation(fields: [courseId], references: [courseId])
  vote        Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([tripId, userId, courseId])
  @@index([tripId])
  @@index([userId])

}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String?  @db.Text
  handicap          Float?
  homeClub          String?
  avatarUrl         String?
  coverUrl          String?
  location          String?
  isAvailableToPlay Boolean  @default(false)
  handicapIndex       Float?
  handicapVerified    Boolean  @default(false)
  ghinNumber          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tags              UserTag[]
  ghinVerifications GhinVerification[]

  @@index([userId])

}

model UserTag {
  id        String      @id @default(cuid())
  userId    String
  profile   UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  tagId     String
  tag       Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, tagId])
  @@index([userId])
  @@index([tagId])

}

model Wishlist {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     Int
  course      Course   @relation("CircleWishlists", fields: [courseId], references: [courseId], onDelete: Cascade)
  circleId    String?
  circle      Circle?  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  notes       String?  @db.Text
  priority    Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([userId, courseId, circleId])
  @@index([userId])
  @@index([circleId])
  @@index([courseId])

}

// ─── Looper Guild (Caddy Community) ───────────────────

enum CaddyStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum CaddyRequestStatus {
  PENDING
  FULFILLED
  CANCELLED
}

model Caddy {
  id              String       @id @default(cuid())
  userId          String?      @unique @map("user_id")
  firstName       String       @map("first_name")
  lastName        String       @map("last_name")
  email           String       @unique
  phone           String?
  bio             String?      @db.Text
  yearsExperience Int?         @map("years_experience")
  photoUrl        String?      @map("photo_url")
  status          CaddyStatus  @default(PENDING)
  appliedAt       DateTime     @default(now()) @map("applied_at")
  approvedAt      DateTime?    @map("approved_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  courses         CaddyCourse[]
  ratings         CaddyRating[]
  requests        CaddyRequestCaddy[]

  user            User?        @relation(fields: [userId], references: [id])

  @@map("caddies")
}

model CaddyCourse {
  id        String   @id @default(cuid())
  caddyId   String   @map("caddy_id")
  courseId   Int      @map("course_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  caddy     Caddy    @relation(fields: [caddyId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  @@unique([caddyId, courseId])
  @@map("caddy_courses")
}

model CaddyRating {
  id         String   @id @default(cuid())
  caddyId    String   @map("caddy_id")
  userId     String   @map("user_id")
  courseId    Int      @map("course_id")
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  caddy      Caddy    @relation(fields: [caddyId], references: [id], onDelete: Cascade)
  user       User     @relation("CaddyRatingsGiven", fields: [userId], references: [id])
  course     Course   @relation(fields: [courseId], references: [courseId])

  @@unique([caddyId, userId, courseId])
  @@map("caddy_ratings")
}

model CaddyRequest {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  courseId     Int                @map("course_id")
  playDate    DateTime?          @map("play_date")
  groupSize   Int?               @map("group_size")
  notes       String?            @db.Text
  status      CaddyRequestStatus @default(PENDING)
  createdAt   DateTime           @default(now()) @map("created_at")

  user        User               @relation("CaddyRequestsMade", fields: [userId], references: [id])
  course      Course             @relation(fields: [courseId], references: [courseId])
  caddies     CaddyRequestCaddy[]

  @@map("caddy_requests")
}

model CaddyRequestCaddy {
  id         String       @id @default(cuid())
  requestId  String       @map("request_id")
  caddyId    String       @map("caddy_id")

  request    CaddyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  caddy      Caddy        @relation(fields: [caddyId], references: [id])

  @@unique([requestId, caddyId])
  @@map("caddy_request_caddies")
}

// ─── Course Readability Analysis ───
// Caches AI-generated hole-by-hole playing advice per course + handicap band
model CourseReadability {
  id              String   @id @default(cuid())
  courseId        Int      @map("course_id")
  handicapBand    String   @map("handicap_band") @db.VarChar(20) // "scratch", "low", "mid", "high", "beginner"
  holeAdvice      Json     @map("hole_advice") // Array of { holeNumber, par, yardage, advice, keyChallenge, recommendedPlay }
  overallStrategy String?  @map("overall_strategy")
  generatedAt     DateTime @default(now()) @map("generated_at")

  course          Course   @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  @@unique([courseId, handicapBand])
  @@map("course_readability")
}

// ─── Content Sources (RSS/Atom feeds for content discovery) ───
model ContentSource {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(200)
  feedUrl       String?   @map("feed_url") @db.VarChar(1000)
  websiteUrl    String    @map("website_url") @db.VarChar(1000)
  iconUrl       String?   @map("icon_url") @db.VarChar(500)
  contentTypes  String[]  @map("content_types")
  isActive      Boolean   @default(true) @map("is_active")
  lastFetchedAt DateTime? @map("last_fetched_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("content_sources")
}

