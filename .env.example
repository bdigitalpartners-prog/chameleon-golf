# Database (Neon PostgreSQL via Supabase)
DATABASE_URL="postgresql://..."

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin
ADMIN_API_KEY=""

# AI Concierge (Perplexity Sonar)
PERPLEXITY_API_KEY=""

# GHIN API (Enhancement 1) — Leave blank to use stubbed data
GHIN_API_KEY=""
GHIN_API_BASE_URL="https://api.ghin.com/api/v1"

# Golf Genius API (Enhancement 4) — Leave blank to use stubbed data
GOLF_GENIUS_API_KEY=""
GOLF_GENIUS_API_BASE_URL="https://api.golfgenius.com/v1"

# ── Feature Flags ──────────────────────────────────────────────
# Set to "true" to enable each enhancement area
FEATURE_GHIN_INTEGRATION="true"
FEATURE_AI_CONCIERGE_DEEP="true"
FEATURE_TRIP_PLANNER="true"
FEATURE_EVENTS_DISCOVERY="true"
FEATURE_GAMIFICATION="true"
FEATURE_EQ_LEAGUES="true"
FEATURE_EQ_ACADEMY="true"
FEATURE_ROUND_HISTORY="true"
